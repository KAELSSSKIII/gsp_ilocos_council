<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-03-15T00:00:00.000Z" agent="Claude" version="21.0.0">
  <diagram name="GSP Docker Deployment" id="gsp-docker-deploy">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- SWIMLANE CONTAINER -->
        <mxCell id="swim" value="" style="shape=table;startSize=0;container=1;collapsible=0;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;align=center;resizeLast=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="0" y="0" width="1160" height="2600" as="geometry" />
        </mxCell>

        <!-- LANE: USER -->
        <mxCell id="lane-user" value="USER" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="260" height="2560" as="geometry" />
        </mxCell>

        <!-- LANE: DOCKER ENGINE -->
        <mxCell id="lane-docker" value="DOCKER ENGINE" style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="280" height="2560" as="geometry" />
        </mxCell>

        <!-- LANE: CONTAINERS -->
        <mxCell id="lane-containers" value="CONTAINERS (RUNTIME)" style="swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="20" width="540" height="2560" as="geometry" />
        </mxCell>

        <!-- ===== USER LANE NODES ===== -->

        <!-- START -->
        <mxCell id="n-start" value="START" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00CC00;strokeColor=#007700;fontColor=#ffffff;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="70" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- Install Docker -->
        <mxCell id="n-install" value="1. Install Docker Desktop&#xa;on server PC&#xa;(WSL 2 backend)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="170" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Copy project -->
        <mxCell id="n-copy" value="2. Copy project to server&#xa;(git clone or file copy)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="280" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Generate JWT -->
        <mxCell id="n-jwt" value="3. Generate JWT_SECRET&#xa;node -e &quot;require('crypto')&#xa;.randomBytes(64).toString('hex')&quot;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="390" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Fill .env.docker -->
        <mxCell id="n-env" value="4. Fill in .env.docker&#xa;· POSTGRES_PASSWORD&#xa;· JWT_SECRET" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="510" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Port decision -->
        <mxCell id="n-port" value="Port 80 in use?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="75" y="620" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- Set custom port -->
        <mxCell id="n-port-alt" value="Set FRONTEND_PORT=8080&#xa;in .env.docker" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="60" y="740" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- Run compose -->
        <mxCell id="n-compose" value="5. Run command:&#xa;docker compose&#xa;--env-file .env.docker&#xa;up -d --build" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="840" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Wait for services -->
        <mxCell id="n-wait" value="6. Wait for all containers&#xa;to become healthy&#xa;(watch: docker compose logs -f)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1100" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Generate bcrypt -->
        <mxCell id="n-bcrypt" value="7. Generate bcrypt hash&#xa;for admin password:&#xa;docker exec -it gsp_backend&#xa;node -e &quot;require('bcryptjs')&#xa;.hash('Pass',10)...&quot;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1390" width="180" height="90" as="geometry" />
        </mxCell>

        <!-- Insert admin -->
        <mxCell id="n-admin" value="8. INSERT admin user&#xa;into public.users&#xa;+ public.profiles (role=admin)&#xa;via psql" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1530" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- Open browser -->
        <mxCell id="n-browser" value="9. Open browser:&#xa;http://SERVER_LAN_IP&#xa;(or http://localhost)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="1660" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- Login decision -->
        <mxCell id="n-login" value="Login&#xa;successful?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="75" y="1770" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- Check admin -->
        <mxCell id="n-fix-login" value="Re-check DB insert&#xa;or bcrypt hash" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="60" y="1900" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- APP LIVE -->
        <mxCell id="n-live" value="APP LIVE 24/7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00CC00;strokeColor=#007700;fontColor=#ffffff;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="2010" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- ===== DOCKER ENGINE LANE NODES ===== -->

        <!-- Build frontend image -->
        <mxCell id="n-build-fe" value="Build Dockerfile.frontend&#xa;① npm ci&#xa;② vite build (reads .env.production)&#xa;③ copy dist/ → nginx image" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="320" y="860" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Build backend image -->
        <mxCell id="n-build-be" value="Build Dockerfile.backend&#xa;① npm ci&#xa;② tsc → dist/server/&#xa;③ npm ci --omit=dev&#xa;④ run as non-root user" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="320" y="980" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Pull postgres -->
        <mxCell id="n-pull-pg" value="Pull postgres:16-alpine&#xa;from Docker Hub" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="320" y="1100" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- Health check postgres -->
        <mxCell id="n-hc-pg" value="postgres healthy?&#xa;(pg_isready check)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="335" y="1190" width="190" height="70" as="geometry" />
        </mxCell>

        <!-- Retry postgres -->
        <mxCell id="n-retry-pg" value="Retry every 10s&#xa;(max 5 retries)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="350" y="1310" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- Health check backend -->
        <mxCell id="n-hc-be" value="backend /health OK?&#xa;(GET :3001/health)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="335" y="1490" width="190" height="70" as="geometry" />
        </mxCell>

        <!-- Retry backend -->
        <mxCell id="n-retry-be" value="Retry every 15s&#xa;(max 3 retries)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="350" y="1610" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- ===== CONTAINERS LANE NODES ===== -->

        <!-- Note: VITE bake -->
        <mxCell id="n-note-vite" value="NOTE: VITE_API_BASE_URL=/api&#xa;is baked into JS bundle at build time.&#xa;Works on any server IP — no rebuild needed." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="860" width="240" height="70" as="geometry" />
        </mxCell>

        <!-- postgres container -->
        <mxCell id="n-pg-container" value="postgres container starts&#xa;Port: 5432 (internal)&#xa;Volume: postgres_data mounted" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="1100" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- Schema init -->
        <mxCell id="n-schema" value="Auto-run db/schema.sql&#xa;(only if postgres_data volume is empty)&#xa;Creates all tables, enums, procedures" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="1210" width="220" height="70" as="geometry" />
        </mxCell>

        <!-- backend container -->
        <mxCell id="n-be-container" value="backend container starts&#xa;node dist/server/index.js&#xa;Port: 3001 (internal)&#xa;Reads DATABASE_URL → postgres:5432" style="shape=mxgraph.cisco.servers.standard_server;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="1390" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- frontend container -->
        <mxCell id="n-fe-container" value="frontend (nginx) container starts&#xa;Port: 80 → host&#xa;· Serves dist/ (static SPA)&#xa;· Proxies /api/* → backend:3001" style="shape=mxgraph.cisco.routers.router;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="1600" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Note: runtime arch -->
        <mxCell id="n-note-arch" value="RUNTIME ARCHITECTURE:&#xa;Browser → nginx:80&#xa;  ├─ /api/* → backend:3001 → postgres:5432&#xa;  └─ /*    → static SPA (React)" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="1730" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Routine ops note -->
        <mxCell id="n-note-ops" value="ROUTINE OPERATIONS:&#xa;• Redeploy: up -d --build&#xa;• Logs: docker compose logs -f [service]&#xa;• Backup: docker exec gsp_postgres pg_dump ...&#xa;• Stop: docker compose down" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="1980" width="260" height="90" as="geometry" />
        </mxCell>

        <!-- ===== EDGES ===== -->

        <!-- start → install -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-start" target="n-install" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- install → copy -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-install" target="n-copy" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- copy → jwt -->
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-copy" target="n-jwt" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- jwt → env -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-jwt" target="n-env" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- env → port -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-env" target="n-port" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- port YES → port-alt -->
        <mxCell id="e6" value="YES" style="edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="n-port" target="n-port-alt" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- port NO → compose -->
        <mxCell id="e7" value="NO" style="edgeStyle=orthogonalEdgeStyle;exitX=1;exitY=0.5;entryX=1;entryY=0;" edge="1" source="n-port" target="n-compose" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- port-alt → compose -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-port-alt" target="n-compose" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- compose → build-fe -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-compose" target="n-build-fe" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- compose → build-be -->
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-compose" target="n-build-be" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- build-fe → note-vite -->
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="n-build-fe" target="n-note-vite" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- build-be → pull-pg -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-build-be" target="n-pull-pg" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- build-fe → pull-pg -->
        <mxCell id="e12b" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-build-fe" target="n-pull-pg" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- pull-pg → pg-container -->
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-pull-pg" target="n-pg-container" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- pull-pg → hc-pg -->
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-pull-pg" target="n-hc-pg" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- pg-container → schema -->
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-pg-container" target="n-schema" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- hc-pg YES → wait (user lane) -->
        <mxCell id="e16" value="YES" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-hc-pg" target="n-wait" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- hc-pg NO → retry-pg -->
        <mxCell id="e17" value="NO" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-hc-pg" target="n-retry-pg" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- retry-pg → hc-pg (loop) -->
        <mxCell id="e18" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;entryX=0;entryY=1;" edge="1" source="n-retry-pg" target="n-hc-pg" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- wait → bcrypt -->
        <mxCell id="e19" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-wait" target="n-bcrypt" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- wait → hc-be -->
        <mxCell id="e20" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-wait" target="n-hc-be" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- hc-be YES → be-container -->
        <mxCell id="e21" value="YES" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-hc-be" target="n-be-container" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- hc-be NO → retry-be -->
        <mxCell id="e22" value="NO" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-hc-be" target="n-retry-be" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- retry-be → hc-be (loop) -->
        <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;entryX=0;entryY=1;" edge="1" source="n-retry-be" target="n-hc-be" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- be-container → fe-container -->
        <mxCell id="e24" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-be-container" target="n-fe-container" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- fe-container → note-arch -->
        <mxCell id="e25" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="n-fe-container" target="n-note-arch" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- bcrypt → admin -->
        <mxCell id="e26" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-bcrypt" target="n-admin" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- admin → browser -->
        <mxCell id="e27" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-admin" target="n-browser" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- browser → login -->
        <mxCell id="e28" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-browser" target="n-login" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- login YES → live -->
        <mxCell id="e29" value="YES" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-login" target="n-live" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- login NO → fix-login -->
        <mxCell id="e30" value="NO" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="n-login" target="n-fix-login" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- fix-login → bcrypt (loop back) -->
        <mxCell id="e31" style="edgeStyle=orthogonalEdgeStyle;exitX=0;exitY=0.5;entryX=0;entryY=0;" edge="1" source="n-fix-login" target="n-bcrypt" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- live → note-ops -->
        <mxCell id="e32" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="n-live" target="n-note-ops" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
